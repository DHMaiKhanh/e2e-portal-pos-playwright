# =====================================================
# Sample env file — copy to .env.local / .env.stage / .env.prod
# DO NOT commit real credentials. Real env files are in .gitignore.
# =====================================================

# Runtime
ENV=local
HEADLESS=true
SLOW_MO=0

# Portal POS app
BASE_URL=http://localhost:3000
API_URL=http://localhost:3000/api
API_TIMEOUT=30000

# Portal credentials (used by global.setup.ts to produce a logged-in session)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Persisted logged-in session reused by UI tests
STORAGE_STATE=src/data/dynamic/auth/admin.json

# Set to a fixed number to make faker-generated test data reproducible.
# Leave blank for fresh random data each run.
FAKER_SEED=

# Logging
LOG_LEVEL=info
